{
  "title": "Flight Booking - Logs",
  "uid": "flight-booking-logs",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Application Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "targets": [
        {
          "expr": "{app=\"flight-booking\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 12 },
      "targets": [
        {
          "expr": "{app=\"flight-booking\", level=\"ERROR\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 3,
      "title": "Log Rate by Level",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (level) (rate({app=\"flight-booking\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ]
    }
  ]
}
