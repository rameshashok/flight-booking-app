{
  "title": "Flight Booking - Spring Boot",
  "uid": "flight-booking",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"flight-booking\"}[1m])",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Response Time (p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"flight-booking\"}[1m]))",
          "legendFormat": "p99 {{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"flight-booking\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"flight-booking\"}",
          "legendFormat": "CPU Usage"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"flight-booking\"}",
          "legendFormat": "Active Connections"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{application=\"flight-booking\", status=~\"5..\"}[1m])",
          "legendFormat": "{{uri}}"
        }
      ]
    }
  ]
}
